[Unit]
Description=YugabyteDB Cluster (yugabyted-managed)
After=network-online.target

[Service]
Type=simple
RemainAfterExit=yes
User=cloud-user
Group=cloud-user
WorkingDirectory=/home/cloud-user

ExecStart=/usr/bin/python3 /home/cloud-user/yugabyte-2024.2.2.2/bin/yugabyted start
ExecStop=/usr/bin/python3 /home/cloud-user/yugabyte-2024.2.2.2/bin/yugabyted stop
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target