{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 38,
  "version": 7,
  "title": "🚀 YugabyteDB Enterprise Monitoring (Dynamic)",

  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up, node_name)",
        "includeAll": true,
        "multi": true
      }
    ]
  },

  "panels": [

    { "type": "stat", "title": "Masters UP",
      "targets": [{ "expr": "sum(up{job=\"yugabyte-masters\", node_name=~\"$node\"})" }],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },

    { "type": "stat", "title": "TServers UP",
      "targets": [{ "expr": "sum(up{job=\"yugabyte-tservers\", node_name=~\"$node\"})" }],
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },

    { "type": "stat", "title": "Cluster Memory (MB)",
      "targets": [{ "expr": "sum(mem_tracker_server{node_name=~\"$node\"}) / 1024 / 1024" }],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },

    { "type": "stat", "title": "Raft Threads",
      "targets": [{ "expr": "sum(threads_running_raft{node_name=~\"$node\"})" }],
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    },

    { "type": "timeseries", "title": "Memory per Node",
      "targets": [{ "expr": "mem_tracker_server{node_name=~\"$node\"} / 1024 / 1024", "legendFormat": "{{node_name}} ({{node_ip}})" }],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },

    { "type": "timeseries", "title": "Raft Threads per Node",
      "targets": [{ "expr": "threads_running_raft{node_name=~\"$node\"}", "legendFormat": "{{node_name}} ({{node_ip}})" }],
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },

    { "type": "timeseries", "title": "Consensus Traffic",
      "targets": [
        { "expr": "rate(proxy_request_bytes_yb_consensus_ConsensusService_UpdateConsensus{node_name=~\"$node\"}[1m])", "legendFormat": "{{node_name}} Req" },
        { "expr": "rate(proxy_response_bytes_yb_consensus_ConsensusService_UpdateConsensus{node_name=~\"$node\"}[1m])", "legendFormat": "{{node_name}} Resp" }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },

    { "type": "timeseries", "title": "RPC Queue Pressure",
      "targets": [{ "expr": "sum by(node_name) (rpcs_in_queue_yb_consensus_ConsensusService{node_name=~\"$node\"})", "legendFormat": "{{node_name}}" }],
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 }
    },

    { "type": "timeseries", "title": "YSQL TPS",
      "targets": [{ "expr": "sum(rate(handler_latency_yb_tserver_PgClientService_Perform_count{node_name=~\"$node\"}[1m]))", "legendFormat": "TPS" }],
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 }
    },

    { "type": "timeseries", "title": "YSQL Avg Latency",
      "targets": [{ "expr": "rate(handler_latency_yb_tserver_PgClientService_Perform_sum{node_name=~\"$node\"}[1m]) / rate(handler_latency_yb_tserver_PgClientService_Perform_count{node_name=~\"$node\"}[1m])", "legendFormat": "Latency" }],
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 }
    },

    { "type": "timeseries", "title": "YSQL RPC Queue",
      "targets": [{ "expr": "sum by(node_name) (rpcs_in_queue_yb_tserver_PgClientService{node_name=~\"$node\"})", "legendFormat": "{{node_name}}" }],
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 }
    },

    { "type": "timeseries", "title": "YCQL TPS",
      "targets": [
        { "expr": "sum(rate(handler_latency_yb_tserver_TabletServerService_Write_count{node_name=~\"$node\"}[1m]))", "legendFormat": "Writes" },
        { "expr": "sum(rate(handler_latency_yb_tserver_TabletServerService_Read_count{node_name=~\"$node\"}[1m]))", "legendFormat": "Reads" }
      ],
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 6 }
    },

    { "type": "timeseries", "title": "Disk Usage",
      "targets": [{ "expr": "sum by(node_name) (rocksdb_current_version_sst_files_size{node_name=~\"$node\"})", "legendFormat": "{{node_name}}" }],
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 6 }
    },

    { "type": "timeseries", "title": "Compaction Load",
      "targets": [
        { "expr": "rate(rocksdb_compact_read_bytes{node_name=~\"$node\"}[1m])", "legendFormat": "Read" },
        { "expr": "rate(rocksdb_compact_write_bytes{node_name=~\"$node\"}[1m])", "legendFormat": "Write" }
      ],
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 6 }
    },

    { "type": "timeseries", "title": "CPU Usage",
      "targets": [{ "expr": "rate(process_cpu_seconds_total{node_name=~\"$node\"}[1m])", "legendFormat": "{{node_name}} ({{node_ip}})" }],
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 6 }
    },
    {
  "type": "table",
  "title": "📦 Node Storage (SST + RAM + OPS)",
  "datasource": "Prometheus",

  "targets": [
    {
      "expr": "max by(instance) (up{job=\"yugabyte-tservers\", node_name=~\"$node\"})",
      "refId": "A"
    },
    {
      "expr": "max by(instance) (process_resident_memory_bytes{job=\"yugabyte-tservers\", node_name=~\"$node\"})",
      "refId": "B"
    },
    {
      "expr": "sum by(instance) (rocksdb_current_version_sst_files_size{job=\"yugabyte-tservers\", node_name=~\"$node\"})",
      "refId": "C"
    },
    {
      "expr": "sum by(instance) (rate(handler_latency_yb_tserver_TabletServerService_Read_count{job=\"yugabyte-tservers\", node_name=~\"$node\"}[1m]))",
      "refId": "D"
    },
    {
      "expr": "sum by(instance) (rate(handler_latency_yb_tserver_TabletServerService_Write_count{job=\"yugabyte-tservers\", node_name=~\"$node\"}[1m]))",
      "refId": "E"
    }
  ],

  "transformations": [
    {
      "id": "reduce",
      "options": {
        "reducers": ["lastNotNull"]
      }
    },
    {
      "id": "joinByField",
      "options": {
        "byField": "instance"
      }
    },
    {
      "id": "organize",
      "options": {
        "renameByName": {
          "instance": "Node",
          "Value #A": "Status",
          "Value #B": "RAM",
          "Value #C": "SST Size",
          "Value #D": "Read OPS",
          "Value #E": "Write OPS"
        }
      }
    }
  ],

  "fieldConfig": {
    "overrides": [
      {
        "matcher": { "id": "byName", "options": "Status" },
        "properties": [
          {
            "id": "mappings",
            "value": [
              {
                "type": "value",
                "options": {
                  "1": { "text": "🟢 Live", "color": "green" },
                  "0": { "text": "🔴 Down", "color": "red" }
                }
              }
            ]
          }
        ]
      },
      {
        "matcher": { "id": "byName", "options": "RAM" },
        "properties": [{ "id": "unit", "value": "bytes" }]
      },
      {
        "matcher": { "id": "byName", "options": "SST Size" },
        "properties": [{ "id": "unit", "value": "bytes" }]
      }
    ]
  },

  "options": {
    "showHeader": true
  },

  "gridPos": {
    "x": 0,
    "y": 44,
    "w": 24,
    "h": 10
  }
}

  ]
}